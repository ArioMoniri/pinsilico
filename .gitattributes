# Default to LF line endings everywhere so Windows CI doesn't drift
* text=auto eol=lf

# Source
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.rs    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
Makefile text eol=lf

# Scripts that run on Windows
*.ps1   text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Binaries
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.pdb   binary
*.sdf   binary
*.mol2  binary
*.gltf  binary
*.glb   binary
*.mp4   binary
*.webm  binary
*.zip   binary
*.tar.gz binary
*.parquet binary
