{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PInSilico",
  "version": "1.5.0",
  "identifier": "com.ariomoniri.pinsilico",
  "build": {
    "beforeDevCommand": "pnpm --filter pinsilico-app dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm --filter pinsilico-app build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PInSilico v1.5.0",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https://github.com https://*.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "In-silico drug discovery: pockets, docking, kinetic simulation.",
    "longDescription": "PInSilico runs the full small-molecule in-silico pipeline locally: fpocket pocket detection, Smina/Vina docking, and a Brownian-dynamics kinetic simulation with dual abstract + atomistic visualisation.",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/pinsilico-sidecar"],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/ArioMoniri/pinsilico/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxQjI3QTQyQUJBNjdBQzkKUldUSmVxYXJRbnF5WVRYTE10WXVJOGtrb20xK1dIMU1uRWhMSDFJUENiUDRYQTBaVzFaYk1EVXIK",
      "dialog": false
    }
  }
}
